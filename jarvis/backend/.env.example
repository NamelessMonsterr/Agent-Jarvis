# ============================================================
# Jarvis v3 — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# ─── LLM Providers (add at least one) ───────────────────────
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GROK_API_KEY=

# ─── Database ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── GitHub ──────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-username/jarvis-devlogs
GITHUB_DEVLOG_BRANCH=jarvis/devlog
GITHUB_DRY_RUN=true               # Set to false when ready for real commits
GITHUB_MIN_DIFF_CHARS=50          # Skip commit if change < 50 chars

# ─── Kaggle (optional, for dataset search) ───────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=

# ─── LinkedIn (post-MVP) ────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Security ────────────────────────────────────────────────
# Production: set to your Vercel frontend URL
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
RATE_LIMIT_PER_MINUTE=30

# ─── Authentication ──────────────────────────────────────────────
# Phase 1: deploy with AUTH_REQUIRED=false, test, then flip to true
AUTH_REQUIRED=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
# Optional: passphrase to issue tokens (leave blank for open dev)
AUTH_TOKEN_SECRET=

# ─── Memory / RAG ────────────────────────────────────────────
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RECENCY_WEIGHT=0.2

# ─── Agent Execution ─────────────────────────────────────────
AGENT_TIMEOUT_S=60
AGENT_MAX_RETRIES=1

# ─── App ─────────────────────────────────────────────────────
DEBUG=false
DEFAULT_USER_ID=local-dev-user
